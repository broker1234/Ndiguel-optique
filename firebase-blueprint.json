{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An e-commerce product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "isNew": { "type": "boolean" }
      },
      "required": ["name", "category", "image"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    }
  }
}
